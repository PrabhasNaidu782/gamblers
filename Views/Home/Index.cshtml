@{
    ViewData["Title"] = "Home";
    var sessionName = Context.Session.GetString("SessionUserName") ?? "";
    var sessionRole = Context.Session.GetString("SessionUserRole") ?? "";
}
<div class="page-header">
    <h4>Welcome, @sessionName</h4>
    <p>Select an option from the sidebar to get started.</p>
</div>
<div class="row g-3">
    @if (sessionRole == "Admin" || sessionRole == "Cashier")
    {
        <div class="col-md-4">
            <a asp-controller="Pos" asp-action="Index" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#dbeafe;color:#1d4ed8;"><i class="fas fa-cash-register"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">POS Billing</div><div class="stat-label">Start a new sale</div></div>
                </div>
            </a>
        </div>
    }
    @if (sessionRole == "Admin" || sessionRole == "Store Manager")
    {
        <div class="col-md-4">
            <a asp-controller="Product" asp-action="Index" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#dcfce7;color:#166534;"><i class="fas fa-box"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">Products</div><div class="stat-label">Manage catalog</div></div>
                </div>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Promotion" asp-action="Index" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fef9c3;color:#854d0e;"><i class="fas fa-tag"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">Promotions</div><div class="stat-label">Manage discounts</div></div>
                </div>
            </a>
        </div>
    }
    @if (sessionRole == "Admin" || sessionRole == "Store Manager" || sessionRole == "Inventory Associate")
    {
        <div class="col-md-4">
            <a asp-controller="Inventory" asp-action="Index" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fce7f3;color:#9d174d;"><i class="fas fa-warehouse"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">Inventory</div><div class="stat-label">View stock levels</div></div>
                </div>
            </a>
        </div>
    }
    @if (sessionRole == "Admin" || sessionRole == "Store Manager")
    {
        <div class="col-md-4">
            <a asp-controller="Report" asp-action="GenerateDailySalesReport" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#ede9fe;color:#5b21b6;"><i class="fas fa-chart-bar"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">Sales Report</div><div class="stat-label">Today's summary</div></div>
                </div>
            </a>
        </div>
    }
    @if (sessionRole == "Admin")
    {
        <div class="col-md-4">
            <a asp-controller="Admin" asp-action="ManageUsers" class="text-decoration-none">
                <div class="stat-card d-flex align-items-center gap-3">
                    <div class="stat-icon" style="background:#fee2e2;color:#991b1b;"><i class="fas fa-users"></i></div>
                    <div><div class="stat-value" style="font-size:16px;">Users</div><div class="stat-label">Manage staff</div></div>
                </div>
            </a>
        </div>
    }
</div>
