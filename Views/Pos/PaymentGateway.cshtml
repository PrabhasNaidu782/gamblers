@model BillViewModel
@{
    ViewData["Title"] = "Payment Gateway";
    string mode = ViewBag.PaymentMode ?? "CARD";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0"><i class="fas fa-shield-alt me-2 text-success"></i>Secure Payment</h4>
                </div>

                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <p class="text-muted mb-1">Total Amount Payable</p>
                        <h2 class="display-6 fw-bold text-primary">Rs @Model.totalAmount.ToString("N2")</h2>
                        <span class="badge bg-light text-dark border">Method: @mode</span>
                    </div>

                    <hr class="my-4" />

                    <form asp-action="CompleteSale" asp-controller="Pos" method="post">
                        <input type="hidden" name="paymentMode" value="@mode" />

                        @if (mode == "UPI")
                        {
                            <div class="payment-section">
                                <div class="text-center mb-3">
                                    <i class="fas fa-mobile-alt fa-3x text-info"></i>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Enter UPI ID</label>
                                    <input type="text" name="upiId" class="form-control form-control-lg text-center" 
                                           placeholder="username@bankid" required autofocus autocomplete="off" />
                                    <div class="form-text text-center mt-2">
                                        Scan the QR on the customer's app or enter ID manually.
                                    </div>
                                </div>
                            </div>
                        }
                        else if (mode == "CARD")
                        {
                            <div class="payment-section">
                                <div class="text-center mb-3">
                                    <i class="fas fa-credit-card fa-3x text-primary"></i>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Cardholder Name</label>
                                    <input type="text" class="form-control" placeholder="AS PRINTED ON CARD" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Card Number</label>
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-lock"></i></span>
                                        <input type="text" class="form-control" placeholder="0000 0000 0000 0000" maxlength="12" required />
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-6">
                                        <label class="form-label fw-bold">Expiry Date</label>
                                        <input type="text" class="form-control" placeholder="MM/YY" pattern="(0[1-9]|1[0-2])\/([0-9]{2})" maxlength="5" required />
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label fw-bold">CVV</label>
                                        <input type="password" class="form-control" placeholder="***" maxlength="3" required />
                                    </div>
                                </div>
                            </div>
                        }

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-success btn-lg py-3 fw-bold">
                                <i class="fas fa-check-circle me-2"></i>PAYMENT DONE
                            </button>
                            
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>GO BACK
                            </a>
                        </div>
                    </form>
                </div>

                <div class="card-footer bg-light text-center py-2">
                    <small class="text-muted">
                        <i class="fas fa-info-circle me-1"></i> 
                        Transaction will be logged under Cashier: <strong>@Context.Session.GetString("SessionUserName")</strong>
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body { background-color: #f4f7f6; }
    .card { border-radius: 15px; overflow: hidden; }
    .form-control:focus { border-color: #198754; box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.25); }
    .btn-lg { border-radius: 10px; }
</style>