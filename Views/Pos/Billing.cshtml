@model BillViewModel
@{
    ViewData["Title"] = "POS Billing";
    var cashierName = Context.Session.GetString("SessionUserName") ?? "";
}

<div class="page-header">
    <h4>POS Billing</h4>
    <p>Scan a barcode to add items to the bill</p>
</div>
@if (TempData["Error"] != null)
{
    <div class = "alert alert-danger mt-2">
        @TempData["Error"]
    </div>
}


<div class="row g-3">
    <div class="col-lg-8">
        @* <div class="card mb-3 border-info shadow-sm">
            <div class="card-header bg-info text-white py-2">
                <span class="small fw-bold"><i class="d-none"></i>Product ID Lookup</span>
            </div>
            <div class="card-body py-2">
                <div class="position-relative">
                    <input type="text" id="idLookupInput" class="form-control form-control-sm" 
                           placeholder="Search by product name..." onkeyup="filterProductIds()" autocomplete="off" />
                    
                    
                </div>
                <div id="copyStatus" class="small mt-1 text-success fw-bold" style="display:none;">
                    <i class="fas fa-check me-1"></i> Copied and pasted!
                </div>
            </div>
        </div> *@

        <div class="card mb-3">
            <div class="card-header">Scan Product</div>
            <div class="card-body">
                <form asp-action="ScanProduct" asp-controller="Pos" method="post">
                    <div class="input-group">
                        <input type="text" name="barcode" id="mainBarcodeField" class="form-control form-control-lg"
                               placeholder="Enter barcode and press Enter..." onkeyup="filterProductIds()"  autofocus autocomplete="off" />
                               <div id="productDataSource" class="list-group shadow-lg d-none">
                        @if (ViewBag.AllProducts != null)
                        {
                            foreach (var p in (IEnumerable<GamblersGrocery.Models.Entities.Product>)ViewBag.AllProducts)
                            {
                                <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center lookup-item" 
                                     data-name="@p.productName.ToLower()">
                                    <span>@p.productName</span>
                                    <button type="button" class="btn btn-sm btn-primary py-0 px-2" onclick="copyToScan('@p.barcode')">
                                        <i class="fas fa-copy me-1"></i> @p.barcode
                                    </button>
                                </div>
                            }
                        }
                    </div>
                        <button class="btn btn-primary btn-lg" type="submit"><i class="fas fa-plus me-1"></i>Add</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Bill Items (@Model.Items.Count)</span>
                @if (Model.Items.Any())
                {
                    <a asp-action="ClearBill" class="btn btn-sm btn-outline-danger">Clear All</a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.Items.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-barcode fa-2x mb-2 opacity-25"></i>
                        <p class="mb-0">No items yet. Scan a barcode above.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead><tr><th>Product</th><th>Unit Price</th><th>Promo</th><th>Qty</th><th>Total</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.productName</strong><br/>
                                            <small class="text-muted"><code>@item.barcode</code></small>
                                        </td>
                                        <td>Rs @item.unitPrice?.ToString("N2")</td>
                                        <td>
                                            @if (item.discountPercent > 0)
                                            {
                                                <span class="badge bg-warning text-dark">@item.discountPercent% OFF</span><br/>
                                                <small class="text-success">-Rs @item.productDiscount.ToString("N2")</small>
                                            }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            <form asp-action="UpdateQty" asp-controller="Pos" method="post">
                                                <input type="hidden" name="productId" value="@item.productId" />
                                                <input type="number" name="quantity" value="@item.quantity" min="1" max="999"
                                                       class="form-control form-control-sm" style="width:70px;"
                                                       onchange="this.form.submit()" />
                                            </form>
                                        </td>
                                        <td><strong>Rs @item.lineTotal.ToString("N2")</strong></td>
                                        <td>
                                            <a asp-action="RemoveItem" asp-route-productId="@item.productId"
                                               class="btn btn-sm btn-outline-danger"><i class="fas fa-times"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header" style="background:#1e2a38;color:#fff;">Bill Summary</div>
            <div class="card-body border-bottom">
                <label class="form-label">Extra Bill Discount (%)</label>
                <form asp-action="ApplyDiscount" asp-controller="Pos" method="post">
                    <div class="input-group input-group-sm">
                        <input type="number" name="discountPercent" value="@Model.billDiscountPercent"
                               min="0" max="100" step="0.5" class="form-control" />
                        <button class="btn btn-outline-secondary" type="submit">Apply</button>
                    </div>
                </form>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                    <span class="text-muted">Subtotal</span>
                    <span>Rs @((Model.subTotal + Model.Items.Sum(i => i.productDiscount)).ToString("N2"))</span>
                </div>
                @if (Model.Items.Any(i => i.discountPercent > 0))
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                        <span class="text-muted">Promotions</span>
                        <span class="text-success">-Rs @Model.Items.Sum(i => i.productDiscount).ToString("N2")</span>
                    </div>
                }
                @if (Model.billDiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                        <span class="text-muted">Bill Discount (@Model.billDiscountPercent%)</span>
                        <span class="text-success">-Rs @Model.billDiscountAmount.ToString("N2")</span>
                    </div>
                }
                <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                    <span style="font-weight:700;font-size:16px;">TOTAL</span>
                    <span style="font-weight:700;font-size:20px;color:#1e2a38;">Rs @Model.totalAmount.ToString("N2")</span>
                </div>
            </div>
            <div class="card-body border-top">
                <label class="form-label">Payment Mode</label>
                <form asp-action="ProcessPayment" asp-controller="Pos" method="post">
                    <div class="row g-2 mb-3">
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="CASH" id="pCash" class="d-none" checked />
                            <label for="pCash" class="pay-btn"><i class="fas fa-money-bill-wave d-block mb-1"></i>CASH</label>
                        </div>
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="CARD" id="pCard" class="d-none" />
                            <label for="pCard" class="pay-btn"><i class="fas fa-credit-card d-block mb-1"></i>CARD</label>
                        </div>
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="UPI" id="pUpi" class="d-none" />
                            <label for="pUpi" class="pay-btn"><i class="fas fa-mobile-alt d-block mb-1"></i>UPI</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100" @(!Model.Items.Any() ? "disabled" : "")>
                        <i class="fas fa-check-circle me-2"></i>Purchase— Rs @Model.totalAmount.ToString("N2")
                    </button>
                </form>
            </div>
        </div>
        <div class="card">
            <div class="card-body py-2 px-3" style="font-size:12px;color:#8fa3b1;">
                <i class="fas fa-user me-1"></i>@cashierName &nbsp;|&nbsp;
                <i class="far fa-clock me-1"></i>@DateTime.Now.ToString("hh:mm tt, dd MMM")
            </div>
        </div>
    </div>
</div>

<style>
    #productDataSource {
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        z-index: 1050;
        max-height: 200px;
        overflow-y: auto;
        background: white;
        border: 1px solid #ced4da;
    }
    .lookup-item { font-size: 13px; cursor: pointer; }
    .pay-btn {
        display: block;
        padding: 10px;
        text-align: center;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        cursor: pointer;
        font-size: 11px;
        font-weight: 600;
        transition: all 0.2s;
    }
    input[type="radio"]:checked + .pay-btn {
        background-color: #1e2a38;
        color: white;
        border-color: #1e2a38;
    }
</style>

<script>
    function filterProductIds() {
        const input = document.getElementById('mainBarcodeField').value.toLowerCase();
        const list = document.getElementById('productDataSource');
        const items = list.getElementsByClassName('lookup-item');
        
        if (input.length < 2) {
            list.classList.add('d-none');
            return;
        }

        let hasResults = false;
        for (let i = 0; i < items.length; i++) {
            const name = items[i].getAttribute('data-name');
            if (name.includes(input)) {
                items[i].classList.remove('d-none');
                hasResults = true;
            } else {
                items[i].classList.add('d-none');
            }
        }

        if (hasResults) list.classList.remove('d-none');
        else list.classList.add('d-none');
    }

    function copyToScan(barcode) {
        // Copy to clipboard
        navigator.clipboard.writeText(barcode);
        
        // Paste into main scan box
        const scanInput = document.getElementById('mainBarcodeField');
        scanInput.value = barcode;
        
        // Show status
        const status = document.getElementById('copyStatus');
        status.style.display = 'block';
        setTimeout(() => { status.style.display = 'none'; }, 2000);

        // Reset search
        document.getElementById('productDataSource').classList.add('d-none');
        document.getElementById('mainBarcodeField').value = '';
        
        // Auto-focus the main scan box
        scanInput.focus();
    }

    // Close list when clicking away
    document.addEventListener('click', function(e) {
        if (!document.getElementById('mainBarcodeField').contains(e.target)) {
            document.getElementById('productDataSource').classList.add('d-none');
        }
    });
</script>