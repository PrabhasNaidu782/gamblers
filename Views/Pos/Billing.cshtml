@model BillViewModel
@{
    ViewData["Title"] = "POS Billing";
    var cashierName = Context.Session.GetString("SessionUserName") ?? "";
}

@* 1. Persistent Alert for Server-Side and Client-Side errors *@
@if (TempData["Error"] != null)
{
    <div id="persistentAlert" class="alert alert-danger alert-dismissible fade show shadow-lg" role="alert"
         style="position: fixed; top: 20px; right: 20px; z-index: 10000; min-width: 300px;">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>Attention:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@* 2. Hidden Template for JavaScript alerts (Out of Stock) *@
<div id="stockAlert" class="alert alert-danger d-none shadow-lg" role="alert" 
     style="position: fixed; top: 20px; right: 20px; z-index: 10000; min-width: 300px;">
    <i class="fas fa-exclamation-circle me-2"></i>
    <span id="stockAlertMessage">Out of stock!</span>
    <button type="button" class="btn-close float-end" onclick="document.getElementById('stockAlert').classList.add('d-none')"></button>
</div>

<div class="page-header">
    <h4>POS Billing</h4>
    <p>Scan a barcode to add items to the bill</p>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header">Scan Product</div>
            <div class="card-body">
                <form asp-action="ScanProduct" asp-controller="Pos" method="post" id="scanForm">
                    <div class="input-group">
                        <input type="text" name="barcode" id="mainBarcodeField" class="form-control form-control-lg"
                               placeholder="Enter barcode and press Enter..." onkeyup="filterProductIds()" autofocus autocomplete="off" />
                        
                        <div id="productDataSource" class="list-group shadow-lg d-none">
                            @if (ViewBag.AllProducts != null)
                            {
                                foreach (var p in (IEnumerable<GamblersGrocery.Models.Entities.Product>)ViewBag.AllProducts)
                                {
                                    @* Logic for Stock Visuals in Search *@
                                    var stockStatus = p.stockQuantity <= 0 ? "bg-danger" : (p.stockQuantity < 10 ? "bg-warning text-dark" : "bg-success");
                                    var stockText = p.stockQuantity <= 0 ? "Out of Stock" : $"Stock: {p.stockQuantity}";

                                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center lookup-item" 
                                         data-name="@p.productName.ToLower()"
                                         data-barcode="@p.barcode"
                                         data-stock="@p.stockQuantity">
                                        <div>
                                            <span class="fw-bold">@p.productName</span>
                                            <br />
                                            <small class="text-muted">@p.barcode</small>
                                            @* Feature: Show stock quantity while searching *@
                                            <span class="badge @stockStatus ms-2">@stockText</span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-primary py-1 px-3" 
                                                onclick="handleProductSelection('@p.barcode', @p.stockQuantity)">
                                            <i class="fas fa-plus me-1"></i> @p.barcode
                                        </button>
                                    </div>
                                }
                            }
                        </div>
                        <button class="btn btn-primary btn-lg" type="submit"><i class="fas fa-plus me-1"></i>Add</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Bill Items (@Model.Items.Count)</span>
                @if (Model.Items.Any())
                {
                    <a asp-action="ClearBill" class="btn btn-sm btn-outline-danger">Clear All</a>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.Items.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-barcode fa-2x mb-2 opacity-25"></i>
                        <p class="mb-0">No items yet. Scan a barcode above.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead><tr><th>Product</th><th>Unit Price</th><th>Promo</th><th>Qty</th><th>Total</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>
                                            <strong>@item.productName</strong><br/>
                                            <small class="text-muted"><code>@item.barcode</code></small>
                                        </td>
                                        <td>Rs @item.unitPrice?.ToString("N2")</td>
                                        <td>
                                            @if (item.discountPercent > 0)
                                            {
                                                <span class="badge bg-warning text-dark">@item.discountPercent% OFF</span><br/>
                                                <small class="text-success">-Rs @item.productDiscount.ToString("N2")</small>
                                            }
                                            else { <span class="text-muted">—</span> }
                                        </td>
                                        <td>
                                            <form asp-action="UpdateQty" asp-controller="Pos" method="post">
                                                <input type="hidden" name="productId" value="@item.productId" />
                                                <input type="number" 
                                                       name="quantity" 
                                                       value="@(item.quantity ?? 1)" 
                                                       min="1" 
                                                       @* max="@item.availableStock"  class="form-control form-control-sm"  *@
                                                       style="width:70px;"
                                                       onchange="validateQty(this, @item.availableStock)" />
                                            </form>
                                        </td>
                                        <td><strong>Rs @item.lineTotal.ToString("N2")</strong></td>
                                        <td>
                                            <a asp-action="RemoveItem" asp-route-productId="@item.productId"
                                               class="btn btn-sm btn-outline-danger"><i class="fas fa-times"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Right Column: Summary & Payment *@
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header" style="background:#1e2a38;color:#fff;">Bill Summary</div>
            <div class="card-body border-bottom">
                <label class="form-label">Extra Bill Discount (%)</label>
                <form asp-action="ApplyDiscount" asp-controller="Pos" method="post">
                    <div class="input-group input-group-sm">
                        <input type="number" name="discountPercent" value="@Model.billDiscountPercent"
                               min="0" max="100" step="0.5" class="form-control" />
                        <button class="btn btn-outline-secondary" type="submit">Apply</button>
                    </div>
                </form>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                    <span class="text-muted">Subtotal</span>
                    <span>Rs @((Model.subTotal + Model.Items.Sum(i => i.productDiscount)).ToString("N2"))</span>
                </div>
                @if (Model.Items.Any(i => i.discountPercent > 0))
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                        <span class="text-muted">Promotions</span>
                        <span class="text-success">-Rs @Model.Items.Sum(i => i.productDiscount).ToString("N2")</span>
                    </div>
                }
                @if (Model.billDiscountAmount > 0)
                {
                    <div class="d-flex justify-content-between mb-2" style="font-size:13px;">
                        <span class="text-muted">Bill Discount (@Model.billDiscountPercent%)</span>
                        <span class="text-success">-Rs @Model.billDiscountAmount.ToString("N2")</span>
                    </div>
                }
                <div class="d-flex justify-content-between mt-3 pt-3 border-top">
                    <span style="font-weight:700;font-size:16px;">TOTAL</span>
                    <span style="font-weight:700;font-size:20px;color:#1e2a38;">Rs @Model.totalAmount.ToString("N2")</span>
                </div>
            </div>
            <div class="card-body border-top">
                <label class="form-label">Payment Mode</label>
                <form asp-action="ProcessPayment" asp-controller="Pos" method="post">
                    <div class="row g-2 mb-3">
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="CASH" id="pCash" class="d-none" checked />
                            <label for="pCash" class="pay-btn"><i class="fas fa-money-bill-wave d-block mb-1"></i>CASH</label>
                        </div>
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="CARD" id="pCard" class="d-none" />
                            <label for="pCard" class="pay-btn"><i class="fas fa-credit-card d-block mb-1"></i>CARD</label>
                        </div>
                        <div class="col-4">
                            <input type="radio" name="paymentMode" value="UPI" id="pUpi" class="d-none" />
                            <label for="pUpi" class="pay-btn"><i class="fas fa-mobile-alt d-block mb-1"></i>UPI</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100" @(!Model.Items.Any() ? "disabled" : "")>
                        <i class="fas fa-check-circle me-2"></i>Purchase— Rs @Model.totalAmount.ToString("N2")
                    </button>
                </form>
            </div>
        </div>
        <div class="card">
            <div class="card-body py-2 px-3" style="font-size:12px;color:#8fa3b1;">
                <i class="fas fa-user me-1"></i>@cashierName &nbsp;|&nbsp;
                <i class="far fa-clock me-1"></i>@DateTime.Now.ToString("hh:mm tt, dd MMM")
            </div>
        </div>
    </div>
</div>

<style>
    #productDataSource { position: absolute; top: 100%; left: 0; right: 0; z-index: 1050; max-height: 250px; overflow-y: auto; background: white; border: 1px solid #ced4da; }
    .lookup-item { font-size: 13px; cursor: pointer; }
    .pay-btn { display: block; padding: 10px; text-align: center; border: 1px solid #dee2e6; border-radius: 6px; cursor: pointer; font-size: 11px; font-weight: 600; transition: all 0.2s; }
    input[type="radio"]:checked + .pay-btn { background-color: #1e2a38; color: white; border-color: #1e2a38; }
</style>

<script>
    // Handles the automatic closing of alerts after 5 seconds
    window.onload = function() {
        const pAlert = document.getElementById('persistentAlert');
        if (pAlert) {
            setTimeout(() => {
                var bsAlert = new bootstrap.Alert(pAlert);
                bsAlert.close();
            }, 5000);
        }
    };

    function triggerStockAlert(message) {
        const alertBox = document.getElementById('stockAlert');
        const alertMessage = document.getElementById('stockAlertMessage');
        if (alertBox && alertMessage) {
            alertMessage.innerText = message;
            alertBox.classList.remove('d-none');
            setTimeout(() => { alertBox.classList.add('d-none'); }, 5000);
        }
    }

    function filterProductIds() {
        const input = document.getElementById('mainBarcodeField').value.toLowerCase();
        const list = document.getElementById('productDataSource');
        const items = list.getElementsByClassName('lookup-item');
        if (input.length < 1) { list.classList.add('d-none'); return; }
        let hasResults = false;
        for (let i = 0; i < items.length; i++) {
            const name = items[i].getAttribute('data-name');
            const barcode = items[i].getAttribute('data-barcode');
            if (name.includes(input) || (barcode && barcode.includes(input))) {
                items[i].classList.remove('d-none');
                hasResults = true;
            } else { items[i].classList.add('d-none'); }
        }
        if (hasResults) list.classList.remove('d-none');
        else list.classList.add('d-none');
    }

    function handleProductSelection(barcode, stock) {
        if (stock <= 0) {
            triggerStockAlert("Cannot add: Product is out of stock.");
            return;
        }
        document.getElementById('mainBarcodeField').value = barcode;
        document.getElementById('productDataSource').classList.add('d-none');
        document.getElementById('scanForm').submit();
    }


    


  function validateQty(input, maxStock) {
    let val = parseInt(input.value);

    // Basic validation
    if (isNaN(val) || val < 1) {
        input.value = 1;
    }

    
    input.form.submit();
}
    
    document.getElementById('scanForm').addEventListener('submit', function(e) {
        const barcodeValue = document.getElementById('mainBarcodeField').value.trim();
        const items = document.getElementsByClassName('lookup-item');
        for (let item of items) {
            if (item.getAttribute('data-barcode') === barcodeValue) {
                const stock = parseInt(item.getAttribute('data-stock'));
                if (stock <= 0) {
                    e.preventDefault();
                    triggerStockAlert("Out of Stock! Cannot add this product.");
                    return false;
                }
            }
        }
    });

    // Close list when clicking away
    document.addEventListener('click', function(e) {
        const mainField = document.getElementById('mainBarcodeField');
        if (mainField && !mainField.contains(e.target)) {
            document.getElementById('productDataSource').classList.add('d-none');
        }
    });
</script>