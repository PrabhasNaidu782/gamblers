@model Promotion
@{ ViewData["Title"] = "Add Promotion"; }
<div class="page-header"><h4>Add Promotion</h4><p>Set a discount for a product</p></div>
<div class="row"><div class="col-lg-6">
<div class="card">
    <div class="card-header">Promotion Details</div>
    <div class="card-body">
        <form asp-action="AddPromotion" method="post">
                    <div class="mb-3">
                        <label class="form-label">Step 1: Select Category</label>
                        <select id="categoryFilter" class="form-select" asp-items="ViewBag.Categories">
                            <option value="">-- All Categories --</option>
                        </select>
                    </div>

                    <div class="mb-3">
    <label class="form-label">Step 2: Search Product</label>
    
    <div class="position-relative"> 
        <div class="input-group">
            <span class="input-group-text"><i class="fas fa-search"></i></span>
            <input type="text" id="productSearch" class="form-control" placeholder="Type product name..." autocomplete="off">
        </div>
        
        <ul id="searchResults" class="list-group position-absolute w-100 shadow-lg" 
            style="display:none; z-index: 1050; top: 100%; left: 0; max-height: 200px; overflow-y: auto;">
            @foreach (var p in ViewBag.ProductList)
            {
                <li class="list-group-item list-group-item-action product-option" 
                    data-id="@p.productId" 
                    data-name="@p.productName" 
                    data-category="@p.category" 
                    style="cursor:pointer">
                    <strong>@p.productName</strong> <small class="text-muted">(@p.category)</small>
                </li>
            }
        </ul>
    </div>
    
    <input type="hidden" asp-for="productId" id="selectedProductId" />
    <span asp-validation-for="productId" class="text-danger small"></span>
</div>
            <div class="mb-3">
                <label asp-for="discountPercent" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="discountPercent" class="form-control" placeholder="e.g. 10.00" />
                    <span class="input-group-text">%</span>
                </div>
                <span asp-validation-for="discountPercent" class="text-danger small"></span>
            </div>
            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="startDate" class="form-label"></label>
                    <input asp-for="startDate" class="form-control" type="date" />
                    <span asp-validation-for="startDate" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="endDate" class="form-label"></label>
                    <input asp-for="endDate" class="form-control" type="date" />
                    <span asp-validation-for="endDate" class="text-danger small"></span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Add Promotion</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div></div>
@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    <script>
        $(document).ready(function () {
            const $search = $('#productSearch');
            const $results = $('#searchResults');
            const $category = $('#categoryFilter');
            const $hiddenId = $('#selectedProductId');

            // Show results when typing
            $search.on('input', function () {
                const query = $(this).val().toLowerCase();
                const selectedCat = $category.val();
                
                if (query.length < 1) {
                    $results.hide();
                    return;
                }

                let foundCount = 0;
                $('.product-option').each(function () {
                    const name = $(this).data('name').toLowerCase();
                    const cat = $(this).data('category');
                    
                    // Match query AND match category (if category is selected)
                    const matchesQuery = name.includes(query);
                    const matchesCat = !selectedCat || cat === selectedCat;

                    if (matchesQuery && matchesCat) {
                        $(this).show();
                        foundCount++;
                    } else {
                        $(this).hide();
                    }
                });

                foundCount > 0 ? $results.show() : $results.hide();
            });

            // Handle clicking a result
            $(document).on('click', '.product-option', function () {
                const id = $(this).data('id');
                const name = $(this).data('name');

                $search.val(name);           // Put name in visible box
                $hiddenId.val(id);           // Put ID in hidden box for database
                $results.hide();             // Hide results
            });

            // Close results if clicking outside
            $(document).on('click', function (e) {
                if (!$(e.target).closest('.mb-3').length) {
                    $results.hide();
                }
            });

            // Reset search if category changes
            $category.on('change', function() {
                $search.val('');
                $hiddenId.val('');
                $results.hide();
            });
        });
    </script>

    <style>
        /* Make the search results look like a real dropdown */
        #searchResults {
            top: 100%;
            left: 0;
        }
        .product-option:hover {
            background-color: #f8f9fa;
        }
    </style>
}
