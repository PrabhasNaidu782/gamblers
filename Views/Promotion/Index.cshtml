@model IEnumerable<Promotion>
@{
    ViewData["Title"] = "Promotions"; 
    var sessionRole = Context.Session.GetString("SessionUserRole") ?? "";
}
<div class="page-header d-flex justify-content-between align-items-start">
    <div><h4>Promotions</h4><p>Manage product discounts</p></div>
    @if (sessionRole == "Store Manager")
    {
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Promotion</a>
    }
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead><tr><th>Product</th><th>Discount</th><th>Start Date</th><th>End Date</th><th>Status</th>
                @if (sessionRole == "Store Manager"){
                <th>Actions</th>
                }    
            </tr></thead>
               
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="6" class="text-center text-muted py-3">No promotions found.</td></tr> }
                @foreach (var p in Model)
                {
                    var today = DateTime.Today;
                    var active = p.startDate <= today && p.endDate >= today;
                    <tr>
                        <td><strong>@p.Product?.productName</strong></td>
                        <td><span class="badge badge-warning">@p.discountPercent% OFF</span></td>
                        <td>@p.startDate.ToString("dd MMM yyyy")</td>
                        <td>@p.endDate.ToString("dd MMM yyyy")</td>
                        <td>@if (active) { <span class="badge badge-success">Active</span> } else { <span class="badge" style="background:#e2e8f0;color:#555;">Inactive</span> }</td>
                    @if (sessionRole == "Store Manager")
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.promotionId" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@p.promotionId" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
