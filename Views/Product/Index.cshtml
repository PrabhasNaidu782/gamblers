@model IEnumerable<Product>
@{ ViewData["Title"] = "Products"; }
<div class="page-header d-flex justify-content-between align-items-start">
    <div><h4>Products</h4><p>Manage your product catalog</p></div>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Product</a>
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead><tr><th>Product Name</th><th>Barcode</th><th>Category</th><th>Price</th><th>Stock</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="6" class="text-center text-muted py-3">No products found. Add one to get started.</td></tr> }
                @foreach (var p in Model)
                {
                    <tr>
                        <td><strong>@p.productName</strong></td>
                        <td><code>@p.barcode</code></td>
                        <td>@p.category</td>
                        <td>Rs @p.price?.ToString("N2")</td>
                        <td>
                            @if (p.stockQuantity == 0) { <span class="stock-out">Out of Stock</span> }
                            else if (p.stockQuantity <= 5) { <span class="stock-low">@p.stockQuantity (Low)</span> }
                            else { <span class="stock-ok">@p.stockQuantity</span> }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.productId" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                            <a asp-action="GetProductDetails" asp-route-id="@p.productId" class="btn btn-sm btn-outline-secondary me-1"><i class="fas fa-eye"></i></a>
                            <a asp-action="Delete" asp-route-id="@p.productId" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
