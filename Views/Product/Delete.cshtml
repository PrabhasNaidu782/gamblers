@model Product
@{
    ViewData["Title"] = "Delete Product";
}

@* 1. Persistent Alert only if the product is locked *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>Restricted:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="page-header"><h4>Delete Product</h4></div>

<div class="row">
    <div class="col-lg-5">
        <div class="card border-danger">
            <div class="card-header text-danger fw-bold">Confirm Deletion</div>
            <div class="card-body">
                <p>Are you sure you want to delete <strong>@Model.productName</strong>?</p>
                
                <table class="table table-sm table-borderless">
                    <tr><td class="text-muted">Barcode</td><td>@Model.barcode</td></tr>
                    <tr><td class="text-muted">Category</td><td>@Model.category</td></tr>
                    <tr><td class="text-muted">Price</td><td>Rs @Model.price?.ToString("N2")</td></tr>
                </table>

                <p class="text-danger small mb-3">
                    <i class="fas fa-exclamation-triangle me-1"></i>This action cannot be undone.
                </p>

                <form asp-action="DeleteConfirmed" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.productId" />
                    
                    <div class="d-flex gap-2">
                        @* 2. The Button is disabled if transactions exist *@
                        @if (ViewBag.HasTransactions == true)
                        {
                            <button type="button" class="btn btn-danger" disabled title="Cannot delete items with sales history">
                                <i class="fas fa-ban me-1"></i> Yes, Delete
                            </button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash-alt me-1"></i> Yes, Delete
                            </button>
                        }
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>