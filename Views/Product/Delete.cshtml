@model Product
@{ ViewData["Title"] = "Delete Product"; }
<div class="page-header"><h4>Delete Product</h4></div>
<div class="row"><div class="col-lg-5">
<div class="card border-danger">
    <div class="card-header text-danger">Confirm Deletion</div>
    <div class="card-body">
        <p>Are you sure you want to delete <strong>@Model.productName</strong>?</p>
        <table class="table table-sm table-borderless">
            <tr><td class="text-muted">Barcode</td><td>@Model.barcode</td></tr>
            <tr><td class="text-muted">Category</td><td>@Model.category</td></tr>
            <tr><td class="text-muted">Price</td><td>Rs @Model.price?.ToString("N2")</td></tr>
        </table>
                @if (!ViewData.ModelState.IsValid)
                {
                    <p class="text-danger fw-bold">
                        @ViewData.ModelState.Values.SelectMany(v => v.Errors).FirstOrDefault()?.ErrorMessage
                    </p>
                }
        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" name="productId" value="@Model.productId" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
</div></div>
