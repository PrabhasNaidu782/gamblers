@model DailySalesReportViewModel
@{ ViewData["Title"] = "Daily Sales Report"; }
<div class="page-header d-flex justify-content-between align-items-start">
    <div><h4>Daily Sales Report</h4><p>@Model.reportDate.ToString("dddd, dd MMMM yyyy")</p></div>
    <form method="get" class="d-flex gap-2 align-items-center">
        <input type="date" name="date" value="@Model.reportDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm" style="width:160px;" />
        <button type="submit" class="btn btn-sm btn-outline-primary">Go</button>
    </form>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="stat-card"><div class="stat-value">Rs @Model.totalSales.ToString("N2")</div><div class="stat-label">Total Sales</div></div>
    </div>
    <div class="col-md-3">
        <div class="stat-card"><div class="stat-value">@Model.totalTransactions</div><div class="stat-label">Transactions</div></div>
    </div>
    <div class="col-md-3">
        <div class="stat-card"><div class="stat-value">Rs @Model.totalDiscount.ToString("N2")</div><div class="stat-label">Total Discount</div></div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            @foreach (var kv in Model.PaymentBreakdown) { <div style="font-size:12px;"><span class="badge badge-info me-1">@kv.Key</span>@kv.Value txns</div> }
            <div class="stat-label">Payment Breakdown</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Transactions</div>
    <div class="table-responsive">
        <table class="table mb-0">
            <thead><tr><th>#</th><th>Cashier</th><th>Items</th><th>Discount</th><th>Final</th><th>Payment</th><th>Time</th></tr></thead>
            <tbody>
                @if (!Model.Transactions.Any()) { <tr><td colspan="7" class="text-center text-muted py-3">No transactions for this date.</td></tr> }
                @foreach (var t in Model.Transactions)
                {
                    <tr>
                        <td>#@t.transactionId</td>
                        <td>@t.cashierName</td>
                        <td>@t.TransactionItems.Count items</td>
                        <td class="text-success">-Rs @t.discountAmount.ToString("N2")</td>
                        <td><strong>Rs @t.finalAmount.ToString("N2")</strong></td>
                        <td><span class="badge badge-info">@t.paymentMode</span></td>
                        <td>@t.transactionDate.ToString("hh:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
