@model IEnumerable<Settlement>
@{ ViewData["Title"] = "Settlements"; }
<div class="page-header d-flex justify-content-between align-items-start">
    <div><h4>Settlements</h4><p>Daily cash settlement records</p></div>
    <a asp-action="GenerateDailySalesReport" class="btn btn-outline-primary"><i class="fas fa-chart-bar me-2"></i>Sales Report</a>
</div>
<div class="card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead><tr><th>#</th><th>Date</th><th>Cashier</th><th>System Total</th><th>Cash In Hand</th><th>Variance</th><th></th></tr></thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-3">No settlements recorded yet.</td></tr> }
                @foreach (var s in Model)
                {
                    <tr>
                        <td>@s.settlementId</td>
                        <td>@s.settlementDate.ToString("dd MMM yyyy")</td>
                        <td>@s.cashierName</td>
                        <td>Rs @s.totalSales.ToString("N2")</td>
                        <td>Rs @s.cashInHand.ToString("N2")</td>
                        <td>
                            @if (s.variance >= 0) { <span class="text-success">+Rs @s.variance.ToString("N2")</span> }
                            else { <span class="text-danger">Rs @s.variance.ToString("N2")</span> }
                        </td>
                        <td><a asp-action="GetSettlementDetails" asp-route-settlementId="@s.settlementId" class="btn btn-sm btn-outline-secondary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
